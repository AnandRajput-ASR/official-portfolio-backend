# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# Set to 'production' in production environment for better security and performance
NODE_ENV = development

# ─── Admin Secret Route ───────────────────────────────────────────────────────
# Access admin via: http://localhost:4200/secure-portal-ar2026
# Change this to something only you know!
ADMIN_SECRET_SLUG=secure-portal-ar2026

# ─── CORS Allowed Origins ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=[
  'http://localhost:4200`',
  'https://www.official-portfolio.com',
  'https://official-portfolio.com'
]

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Your Gmail address
GMAIL_USER=userMail@gmail.com
# Gmail App Password (NOT your regular password)
# Generate at: myaccount.google.com → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=portfolio_anand_rajput_secret_2026_change_in_prod
JWT_EXPIRES_IN = 1h

# Where to send notification emails (your inbox)
NOTIFY_EMAIL=userMail@gmail.com

# ─── Supabase (Storage for resume PDF) ────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
# Use the SERVICE ROLE key (not the anon key) — backend only, never expose to frontend
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Bucket to create in Supabase Dashboard → Storage → New Bucket → name: "resume", Public: OFF
SUPABASE_RESUME_BUCKET=resume