# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# URL-encode special chars in password: @ => %40, $ => %24, ^ => %5E, & => %26
DATABASE_URL=postgresql://postgres:YOUR_ENCODED_PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# ─── Auth / Security (required) ───────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
ADMIN_SECRET_SLUG=replace-with-a-secret-admin-slug

# Set true when deployed behind reverse proxy (Nginx/Cloudflare/Render/etc.)
TRUST_PROXY=false

# ─── CORS (comma-separated origins) ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:4200,https://your-domain.com

# ─── Frontend URL (used in reset email links) ─────────────────────────────────
SITE_URL=http://localhost:4200

# ─── Email (optional but recommended) ─────────────────────────────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
NOTIFY_EMAIL=you@gmail.com

# Optional SMTP tuning for cloud runtimes (Render/Railway/etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_CONNECTION_TIMEOUT=30000
SMTP_GREETING_TIMEOUT=30000
SMTP_SOCKET_TIMEOUT=60000
SMTP_DISABLE_PORT_FALLBACK=false

# ─── Email provider selector ──────────────────────────────────────────────────
# brevo  → use Brevo HTTP API (works on Render/Railway, 300 emails/day free)
# gmail  → use Gmail SMTP + Resend fallback
# (unset) → auto: brevo if BREVO_API_KEY present, otherwise gmail
EMAIL_PROVIDER=brevo

# ─── Brevo HTTP API (recommended for cloud deployments) ───────────────────────
# Sign up at https://brevo.com → API Keys → Create key
# Sender email MUST be verified in Brevo (Settings → Senders & IPs)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=you@gmail.com
BREVO_SENDER_NAME=Portfolio Bot

# ─── Optional HTTPS fallback if Gmail SMTP also fails ─────────────────────────
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# ─── Supabase Storage (resume upload) ─────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_RESUME_BUCKET=resume